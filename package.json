{
  "name": "git-ninja",
  "displayName": "Git Ninja",
  "description": "Generate commit messages with Ollama, toggle file exclude rules, and checkout files from another branch.",
  "version": "1.2.0",
  "publisher": "KabirKhyrul",
  "icon": "icon.webp",
  "author": {
    "name": "Git Ninja Team"
  },
  "license": "MIT",
  "homepage": "https://github.com/kabirkhyrul/git-ninja",
  "repository": {
    "type": "git",
    "url": "https://github.com/kabirkhyrul/git-ninja.git"
  },
  "bugs": {
    "url": "https://github.com/kabirkhyrul/git-ninja/issues"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "git",
    "ollama",
    "commit-message",
    "exclude",
    "branch",
    "cleanup",
    "clean",
    "prune",
    "version control",
    "file management",
    "ignore files",
    "git tools",
    "repository management",
    "gitignore",
    "orphaned branches"
  ],
  "main": "./dist/extension.js",
  "extensionDependencies": [
    "vscode.git"
  ],
  "contributes": {
    "commands": [
      {
        "command": "gitNinja.generateCommitMessage",
        "title": "Git Ninja: Generate Commit Message",
        "icon": "$(chat-sparkle)"
      },
      {
        "command": "gitNinja.toggleExcludeFile",
        "title": "Git Ninja: Toggle Exclude File"
      },
      {
        "command": "gitNinja.checkoutFileFromBranch",
        "title": "Git Ninja: Checkout File From Branch"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "when": "scmProvider == git",
          "command": "gitNinja.generateCommitMessage",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "when": "resourceScheme == file",
          "command": "gitNinja.toggleExcludeFile",
          "group": "navigation"
        },
        {
          "when": "resourceScheme == file",
          "command": "gitNinja.checkoutFileFromBranch",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "when": "resourceScheme == file",
          "command": "gitNinja.toggleExcludeFile",
          "group": "navigation"
        },
        {
          "when": "resourceScheme == file",
          "command": "gitNinja.checkoutFileFromBranch",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Git Ninja",
      "properties": {
        "gitNinja.apiUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434/api/generate",
          "description": "Full Ollama generate API URL."
        },
        "gitNinja.model": {
          "type": "string",
          "default": "llama3.2",
          "description": "Ollama model used to generate commit messages."
        },
        "gitNinja.systemPrompt": {
          "type": "string",
          "default": "You write concise, high-quality conventional commit messages. Return only the final commit message. Prefer a single line. Use imperative mood.",
          "description": "System prompt sent to Ollama."
        },
        "gitNinja.diffMaxChars": {
          "type": "number",
          "default": 12000,
          "minimum": 1000,
          "description": "Maximum git diff characters included in the prompt."
        },
        "gitNinja.debug": {
          "type": "boolean",
          "default": true,
          "description": "Enable progress debug output in the Git Ninja output channel."
        },
        "gitNinja.applyToAllRepositories": {
          "type": "boolean",
          "default": true,
          "description": "When the command is run without a specific SCM repository context, generate commit messages for all open git repositories."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./ && vsce package",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.9.3"
  }
}
